# Copy this file to .env and fill in the values
# cp .env.example .env

AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme

# Extra Python packages installed on container start
_PIP_ADDITIONAL_REQUIREMENTS=requests

# Optional: CoinGecko API key for higher rate limits
# Get a free Demo key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# CoinMarketCap API key — required for crypto_CoinMarketCap_market_snapshots DAG
# Get a key at https://coinmarketcap.com/api/
CMC_API_KEY=
